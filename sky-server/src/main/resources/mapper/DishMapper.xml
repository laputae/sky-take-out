<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.sky.mapper.DishMapper">
    <select id="pageQuery" resultType="com.sky.vo.DishVO">
        select d.*,c.name as categoryName from dish d left outer join category c on d.category_id=c.id
        <where>
            <if test="categoryId!=null">
                and d.category_id =#{categoryId}
            </if>
            <if test="name!=null and name!=''">
                and d.name like concat('%', #{name}, '%')
            </if>
            <if test="status!=null">
                and d.status=#{status}
            </if>
        </where>
        order by d.create_time desc
    </select>
    <delete id="deleteBatch">
        DELETE FROM dish
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    <update id="update" parameterType="com.sky.entity.Dish">
        update dish
        <set>
            <if test="name !=null and name!=''">
                name =#{name},
            </if>
            <if test="categoryId!=null">
                category_id=#{categoryId},
            </if>
            <if test="price !=null">
                price=#{price},
            </if>
            <if test="image !=null and image!=''">
                image=#{image},
            </if>
            <if test="description!=null and description !=''">
                description =#{description},
            </if>
            <if test="status!=null">
                status=#{status},
            </if>
            <if test="updateTime !=null">
                update_time=#{updateTime},
            </if>
            <if test="updateUser!=null">
                update_user=#{updateUser}
            </if>
            where id=#{id}
        </set>
    </update>
    <resultMap id="dishVoMap" type="com.sky.vo.DishVO">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="price" column="price"/>
        <result property="image" column="image"/>
        <result property="description" column="description"/>
        <result property="status" column="status"/>
        <result property="updateTime" column="update_time"/>
        <result property="categoryId" column="category_id"/>
        <result property="categoryName" column="category_name"/>

        <collection property="flavors" ofType="com.sky.entity.DishFlavor">
            <id property="id" column="df_id"/>
            <result property="name" column="df_name"/>
            <result property="value" column="df_value"/>
        </collection>
    </resultMap>

    <select id="queryByIdWithFlavor" resultMap="dishVoMap">
        SELECT d.*,
               c.name   AS category_name,
               df.id    AS df_id,
               df.name  AS df_name,
               df.value AS df_value
        FROM dish d
                 LEFT JOIN category c ON d.category_id = c.id
                 LEFT JOIN dish_flavor df ON d.id = df.dish_id
        WHERE d.id = #{id}
    </select>
</mapper>